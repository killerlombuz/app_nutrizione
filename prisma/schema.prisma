generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Multi-tenancy ---

model Professional {
  id        String   @id @default(cuid())
  authId    String   @unique
  name      String
  title     String?
  email     String   @unique
  phone     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patients          Patient[]
  foods             Food[]
  recipes           Recipe[]
  instructions      DietaryInstruction[]
  supplements       Supplement[]
  mealPlanTemplates MealPlanTemplate[]

  @@map("professionals")
}

// --- Pazienti ---

model Patient {
  id             String        @id @default(cuid())
  professionalId String
  professional   Professional  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  name           String
  birthDate      DateTime?
  heightCm       Float?
  gender         Gender?
  email          String?
  phone          String?
  notes          String?
  targetWeightKg   Float?
  targetBodyFatPct Float?
  targetNotes      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  visits       Visit[]
  mealPlans    MealPlan[]
  supplements  PatientSupplement[]
  conditions   PatientCondition[]
  patientNotes PatientNote[]

  @@index([professionalId])
  @@map("patients")
}

enum Gender {
  M
  F
}

// --- Visite / Misure Antropometriche ---

model Visit {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  date      DateTime

  weightKg Float?

  // Plicometria (7 siti)
  plicChest       Float? // plic_petto
  plicTricep      Float? // plic_tricipite
  plicAxillary    Float? // plic_ascella
  plicSubscapular Float? // plic_scapola
  plicSuprailiac  Float? // plic_soprailiaca
  plicAbdominal   Float? // plic_addominale
  plicThigh       Float? // plic_coscia

  // Circonferenze (11 siti)
  circNeck         Float?
  circChest        Float? // circ_torace
  circArmRelaxed   Float? // circ_braccio_rilassato
  circArmFlexed    Float? // circ_braccio_contratto
  circWaist        Float? // circ_vita
  circLowerAbdomen Float? // circ_addome_basso
  circHips         Float?
  circUpperThigh   Float? // circ_coscia_alta
  circMidThigh     Float? // circ_coscia_media
  circLowerThigh   Float? // circ_coscia_bassa
  circCalf         Float? // circ_polpaccio

  // Valori calcolati
  bmi         Float?
  bodyFatPct  Float?
  fatMassKg   Float?
  leanMassKg  Float?
  formulaUsed String? @default("f_media")

  createdAt DateTime @default(now())

  @@index([patientId, date])
  @@map("visits")
}

// --- Alimenti ---

model Food {
  id             String        @id @default(cuid())
  professionalId String?
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  name           String
  category       FoodCategory?
  kcalPer100g    Float         @default(0)
  fatG           Float         @default(0)
  satFatG        Float         @default(0)
  carbG          Float         @default(0)
  sugarG         Float         @default(0)
  proteinG       Float         @default(0)
  fiberG         Float         @default(0)
  isFodmap       Boolean       @default(false)
  isNickel       Boolean       @default(false)
  isGlutenFree   Boolean       @default(false)
  isLactoseFree  Boolean       @default(false)
  notes          String?

  mealOptions       MealOption[]
  recipeIngredients RecipeIngredient[]

  @@unique([professionalId, name])
  @@index([category])
  @@map("foods")
}

enum FoodCategory {
  FRUTTA
  FRUTTA_SECCA
  FRUTTA_ESSICCATA
  VERDURA
  LEGUMI_E_PROTEINE_VEGETALI
  UOVA_E_ALBUMI
  LATTICINI_E_SOSTITUTI
  CARNE
  PESCE
  CEREALI
  CEREALI_ELABORATI
  OLI_BURRO_E_CIOCCOLATA
  JUNK_FOOD
  ALCOLICI
  ALTRO
}

// --- Piani Dietetici ---

model MealPlan {
  id              String         @id @default(cuid())
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name            String?
  date            DateTime       @default(now())
  activityLevelId String?
  activityLevel   ActivityLevel? @relation(fields: [activityLevelId], references: [id])
  numVariants     Int            @default(1)

  totalKcalRest     Float?
  totalKcalWorkout1 Float?
  totalKcalWorkout2 Float?
  proteinTargetMin  Float?
  proteinTargetMax  Float?

  workout1Name String?
  workout1Kcal Float?
  workout2Name String?
  workout2Kcal Float?
  deficitKcal  Float? @default(0)

  // Distribuzione pasti (percentuali)
  pctBreakfast Float @default(0.17)
  pctLunch     Float @default(0.45)
  pctDinner    Float @default(0.25)
  pctSnack1    Float @default(0.065)
  pctSnack2    Float @default(0.065)
  pctSnack3    Float @default(0.0)

  notes      String?
  shareToken String?  @unique @default(cuid())
  createdAt  DateTime @default(now())

  mealTemplates MealTemplate[]

  @@index([patientId])
  @@map("meal_plans")
}

model MealTemplate {
  id           String   @id @default(cuid())
  mealPlanId   String
  mealPlan     MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  mealType     MealType
  sortOrder    Int      @default(0)
  kcalRest     Float?
  kcalWorkout1 Float?
  kcalWorkout2 Float?
  notes        String?

  options        MealOption[]
  weeklyExamples WeeklyExample[]

  @@map("meal_templates")
}

enum MealType {
  COLAZIONE
  SPUNTINO_MATTINA
  PRANZO
  SPUNTINO_POMERIGGIO
  CENA
  SPUNTINO_SERA
}

model MealOption {
  id             String       @id @default(cuid())
  mealTemplateId String
  mealTemplate   MealTemplate @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  optionGroup    String?
  foodId         String?
  food           Food?        @relation(fields: [foodId], references: [id])
  foodName       String?
  gramsRest      Float?
  gramsWorkout1  Float?
  gramsWorkout2  Float?
  isFixed        Boolean      @default(false)
  sortOrder      Int          @default(0)
  notes          String?

  @@map("meal_options")
}

model WeeklyExample {
  id             String       @id @default(cuid())
  mealTemplateId String
  mealTemplate   MealTemplate @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  carbFood       String?
  vegetable      String?
  proteinFood    String?

  @@map("weekly_examples")
}

// --- Dati di Riferimento ---

model ActivityLevel {
  id              String @id @default(cuid())
  name            String @unique
  bmrMultiplier   Float
  fatGPerKgMin    Float
  fatGPerKgMax    Float
  carbGPerKgMin   Float
  carbGPerKgMax   Float
  proteinGPerKgMin Float
  proteinGPerKgMax Float

  mealPlans MealPlan[]

  @@map("activity_levels")
}

model SportActivity {
  id                 String @id @default(cuid())
  name               String @unique
  kcalPerHourPerKg   Float
  defaultDurationMin Int    @default(60)

  @@map("sport_activities")
}

model BodyFatReference {
  id        String @id @default(cuid())
  ageMin    Int
  ageMax    Int
  gender    Gender
  category  String
  fatPctMin Float
  fatPctMax Float

  @@map("body_fat_reference")
}

// --- Ricette ---

model Recipe {
  id             String        @id @default(cuid())
  professionalId String?
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  name           String
  totalKcal      Float?
  kcalPerPortion Float?
  portions       Float?
  notes          String?
  imageUrl       String?
  prepTimeMin    Int?
  cookTimeMin    Int?
  difficulty     String?
  instructions   String?
  isVegetarian   Boolean       @default(false)
  isVegan        Boolean       @default(false)
  isGlutenFree   Boolean       @default(false)
  isLactoseFree  Boolean       @default(false)
  isLowFodmap    Boolean       @default(false)

  ingredients RecipeIngredient[]

  @@index([professionalId, name])
  @@map("recipes")
}

model RecipeIngredient {
  id        String @id @default(cuid())
  recipeId  String
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodId    String?
  food      Food?  @relation(fields: [foodId], references: [id])
  foodName  String?
  grams     Float?
  sortOrder Int    @default(0)

  @@map("recipe_ingredients")
}

// --- Istruzioni Dietetiche ---

model DietaryInstruction {
  id             String        @id @default(cuid())
  professionalId String?
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  category       String
  title          String?
  content        String?
  sortOrder      Int           @default(0)

  @@map("dietary_instructions")
}

// --- Integratori ---

model Supplement {
  id             String        @id @default(cuid())
  professionalId String?
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  defaultDosage  String?
  timing         String?

  patientSupplements PatientSupplement[]

  @@map("supplements")
}

model PatientSupplement {
  id           String     @id @default(cuid())
  patientId    String
  patient      Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  supplementId String
  supplement   Supplement @relation(fields: [supplementId], references: [id])
  dosage       String?
  timing       String?
  notes        String?
  createdAt    DateTime   @default(now())

  @@map("patient_supplements")
}

model PatientCondition {
  id            String  @id @default(cuid())
  patientId     String
  patient       Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  conditionName String
  notes         String?

  @@map("patient_conditions")
}

// --- Template Piani Dieta ---

model MealPlanTemplate {
  id             String   @id @default(cuid())
  professionalId String?
  name           String
  description    String?
  dietType       String?
  pctBreakfast   Float    @default(0.17)
  pctLunch       Float    @default(0.45)
  pctDinner      Float    @default(0.25)
  pctSnack1      Float    @default(0.065)
  pctSnack2      Float    @default(0.065)
  pctSnack3      Float    @default(0.0)
  createdAt      DateTime @default(now())

  professional Professional?          @relation(fields: [professionalId], references: [id])
  meals        MealPlanTemplateMeal[]

  @@index([professionalId])
  @@map("meal_plan_templates")
}

model MealPlanTemplateMeal {
  id         String   @id @default(cuid())
  templateId String
  mealType   MealType
  foods      MealPlanTemplateFood[]

  template MealPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("meal_plan_template_meals")
}

model MealPlanTemplateFood {
  id             String       @id @default(cuid())
  templateMealId String
  foodCategory   FoodCategory
  portionType    String
  isFixed        Boolean      @default(false)
  sortOrder      Int          @default(0)

  templateMeal MealPlanTemplateMeal @relation(fields: [templateMealId], references: [id], onDelete: Cascade)

  @@map("meal_plan_template_foods")
}

// --- Note cliniche ---

model PatientNote {
  id        String   @id @default(cuid())
  patientId String
  content   String
  category  String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@map("patient_notes")
}
